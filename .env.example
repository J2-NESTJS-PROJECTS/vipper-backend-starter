# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/nestjs_sap_db?schema=public"

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# SAP RFC Connection
SAP_HOST=your-sap-host
SAP_SYSNR=00
SAP_CLIENT=100
SAP_USER=your-sap-user
SAP_PASSWD=your-sap-password
SAP_LANG=EN
SAP_POOL_SIZE=5

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# API Key/Token Authentication (optional)
API_AUTH_ENABLED=false

# Legacy single credential fallback (recommended only while migrating to DB-backed credentials)
API_AUTH_KEY=your_api_key_here
API_AUTH_TOKEN=your_api_token_here
API_AUTH_USER=api-client

# API credential seed helpers
SEED_API_CREDENTIAL_USER=api-client
SEED_API_CREDENTIAL_NAME=VTEX Integration
SEED_API_CREDENTIAL_KEY=
SEED_API_CREDENTIAL_TOKEN=
SEED_API_CREDENTIAL_EXPIRES_AT=

# Logging
LOG_LEVEL=debug
