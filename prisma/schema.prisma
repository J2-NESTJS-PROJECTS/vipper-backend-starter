generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  USER
  API_CLIENT
}

enum PointRedemptionStatus {
  PENDING
  PROCESSED
  REJECTED
  FAILED
}

enum PointRefundStatus {
  PENDING
  PROCESSED
  REJECTED
  FAILED
}

model Role {
  id          String       @id @default(uuid())
  name        RoleType     @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  action      String
  resource    String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  username         String            @unique
  password         String
  firstName        String?
  lastName         String?
  isActive         Boolean           @default(true)
  roleId           String
  role             Role              @relation(fields: [roleId], references: [id])
  refreshTokens    RefreshToken[]
  apiCredentials   ApiCredential[]
  pointRedemptions PointRedemption[] @relation("PointRedemptionRequestedByUser")
  pointRefunds     PointRefund[]     @relation("PointRefundRequestedByUser")
  auditLogs        AuditLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastLoginAt      DateTime?

  @@map("users")
}

model ApiCredential {
  id         String   @id @default(uuid())
  name       String?
  keyHash    String   @unique
  tokenHash  String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("api_credentials")
}

model PointRedemption {
  id                 String                @id @default(uuid())
  orderId            String
  channel            String                @default("ECOMMERCE")
  storeCode          String?
  documentNumber     String
  cardNumber         String
  customerName       String?
  purchaseAmount     Decimal               @db.Decimal(15, 2)
  pointsUsed         Decimal               @db.Decimal(15, 3)
  currency           String                @default("USD")
  transactionAt      DateTime
  notes              String?
  status             PointRedemptionStatus @default(PENDING)
  sapReference       String?
  sapMessage         String?
  remainingPoints    Decimal?              @db.Decimal(15, 3)
  requestPayload     Json
  sapRequestPayload  Json?
  sapResponsePayload Json?
  errorMessage       String?
  requestedByUserId  String?
  requestedByUser    User?                 @relation("PointRedemptionRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  refunds            PointRefund[]
  processedAt        DateTime?
  rejectedAt         DateTime?
  failedAt           DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@unique([channel, orderId])
  @@index([status])
  @@index([transactionAt])
  @@index([documentNumber])
  @@index([cardNumber])
  @@index([requestedByUserId])
  @@map("point_redemptions")
}

model PointRefund {
  id                 String            @id @default(uuid())
  refundId           String
  channel            String            @default("ECOMMERCE")
  originalOrderId    String
  storeCode          String?
  pointRedemptionId  String
  pointRedemption    PointRedemption   @relation(fields: [pointRedemptionId], references: [id], onDelete: Restrict)
  documentNumber     String
  cardNumber         String
  customerName       String?
  refundAmount       Decimal           @db.Decimal(15, 2)
  pointsRefunded     Decimal           @db.Decimal(15, 3)
  currency           String            @default("USD")
  transactionAt      DateTime
  reason             String?
  notes              String?
  status             PointRefundStatus @default(PENDING)
  sapReference       String?
  sapMessage         String?
  remainingPoints    Decimal?          @db.Decimal(15, 3)
  requestPayload     Json
  sapRequestPayload  Json?
  sapResponsePayload Json?
  errorMessage       String?
  requestedByUserId  String?
  requestedByUser    User?             @relation("PointRefundRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  processedAt        DateTime?
  rejectedAt         DateTime?
  failedAt           DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([channel, refundId])
  @@index([originalOrderId])
  @@index([pointRedemptionId])
  @@index([status])
  @@index([transactionAt])
  @@index([documentNumber])
  @@index([cardNumber])
  @@index([requestedByUserId])
  @@map("point_refunds")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ipAddress   String?
  userAgent   String?

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  resource    String
  resourceId  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  statusCode  Int?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
