{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug NestJS",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect-brk",
                "-r",
                "ts-node/register",
                "-r",
                "tsconfig-paths/register"
            ],
            "args": [
                "src/main.ts"
            ],
            "cwd": "${workspaceFolder}",
            "autoAttachChildProcesses": true,
            "restart": true,
            "protocol": "inspector",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}